{
  "expo": {
    "name": "",
    "slug": "Al-Ukhuwah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-AlUkhuwah-noBg-color.png",
    "scheme": "muslimapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikasi membutuhkan akses kamera untuk fitur arah kiblat berbasis kamera.",
        "NSMicrophoneUsageDescription": "Aplikasi membutuhkan akses mikrofon untuk kompatibilitas penggunaan kamera web.",
        "NSLocationWhenInUseUsageDescription": "Aplikasi membutuhkan lokasi untuk menentukan arah kiblat dengan akurat.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Muslimapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-AlUkhuwah-noBg-color.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-AlUkhuwah-noBg-color.png",
          "imageWidth": 500,
          "resizeMode": "fit",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aplikasi membutuhkan lokasi untuk menentukan arah kiblat dengan akurat."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Aplikasi membutuhkan akses kamera untuk fitur arah kiblat berbasis kamera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
